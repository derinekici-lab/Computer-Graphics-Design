        private void UpdateStatus(string actionText = "")
        {
            string modeText = GetModeText();
            string selectedText = selectedShape == null ? "None" : GetShapeDisplayName(selectedShape);

            string message = "Mode: " + modeText + " | Selected: " + selectedText;

            if (!string.IsNullOrWhiteSpace(actionText))
                message += " | " + actionText;

            statusLabel.Text = message;
        }

        private string GetModeText()
        {
            switch (currentMode)
            {
                case EditorMode.CreateSquare:
                    return "Create Square";
                case EditorMode.CreateTriangle:
                    return "Create Triangle";
                case EditorMode.CreateCircle:
                    return "Create Circle";
                case EditorMode.CreatePentagon:
                    return "Create Pentagon";
                case EditorMode.CreateHexagon:
                    return "Create Hexagon";
                case EditorMode.CreateStar:
                    return "Create Star";
                case EditorMode.CreateDiamond:
                    return "Create Diamond";
                case EditorMode.CreateEllipse:
                    return "Create Ellipse";
                default:
                    return "None";
            }
        }

        private string GetShapeDisplayName(Shape shape)
        {
            if (shape is Square) return "Square";
            if (shape is Triangle) return "Triangle";
            if (shape is CircleShape) return "Circle";
            if (shape is PentagonShape) return "Pentagon";
            if (shape is HexagonShape) return "Hexagon";
            if (shape is StarShape) return "Star";
            if (shape is DiamondShape) return "Diamond";
            if (shape is EllipseShape) return "Ellipse";
            return "Shape";
        }

