        }

        private void UndoAction(object sender, EventArgs e)
        {
            Undo();
        }

        private void RedoAction(object sender, EventArgs e)
        {
            Redo();
        }

        private void Undo()
        {
            if (undoStack.Count == 0)
            {
                UpdateStatus("Nothing to undo.");
                return;
            }

            redoStack.Push(CaptureState());
            RestoreState(undoStack.Pop());
            UpdateStatus("Undo completed.");
        }

        private void Redo()
        {
            if (redoStack.Count == 0)
            {
                UpdateStatus("Nothing to redo.");
                return;
            }

            undoStack.Push(CaptureState());
            RestoreState(redoStack.Pop());
            UpdateStatus("Redo completed.");
        }

        private void SaveStateForUndo()
        {
            undoStack.Push(CaptureState());
            redoStack.Clear();
        }

        private EditorState CaptureState()
        {
            return new EditorState(shapes, selectedShape);
        }

        private void RestoreState(EditorState state)
        {
            shapes.Clear();

            foreach (Shape shape in state.Shapes)
                shapes.Add(shape.Clone());

            selectedShape = null;
            if (state.SelectedIndex >= 0 && state.SelectedIndex < shapes.Count)
                selectedShape = shapes[state.SelectedIndex];

            SelectOnly(selectedShape);
            ResetInteractionFlags();
            currentMode = EditorMode.None;
            Invalidate();
        }

        private void ResetInteractionFlags()
        {
            clickNumber = 0;
            isPreviewing = false;
            isDraggingShape = false;
            isResizingShape = false;
            activeHandleIndex = -1;
            didDragOrResize = false;
            interactionUndoSaved = false;
        }

        private void Form1_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyCode == Keys.F1)
            {
                ShowControlsHelp(sender, EventArgs.Empty);
                e.Handled = true;
                return;
            }

            if (e.Control && e.KeyCode == Keys.C)
            {
                CopySelectedShape(sender, EventArgs.Empty);
                e.Handled = true;
                return;
            }

            if (e.Control && e.KeyCode == Keys.V)
            {
                PasteClipboardShape(sender, EventArgs.Empty);
                e.Handled = true;
                return;
            }

            if (e.Control && e.KeyCode == Keys.Z)
            {
                Undo();
                e.Handled = true;
                return;
            }

            if (e.Control && e.KeyCode == Keys.Y)
            {
                Redo();
                e.Handled = true;
                return;
            }

            if (e.KeyCode == Keys.R)
            {
                RotateSelectedByCustomAngle(sender, EventArgs.Empty);
                e.Handled = true;
                return;
            }

            if (selectedShape == null)
                return;

            if (e.KeyCode == Keys.Left)
            {
                MoveSelected(-10, 0);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Right)
            {
                MoveSelected(10, 0);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Up)
            {
                MoveSelected(0, -10);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Down)
            {
                MoveSelected(0, 10);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Q)
            {
                RotateSelected(-15);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.E)
            {
                RotateSelected(15);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Oemplus || e.KeyCode == Keys.Add)
            {
                ScaleSelected(1.1f);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.OemMinus || e.KeyCode == Keys.Subtract)
            {
                ScaleSelected(0.9f);
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.H)
            {
                ReflectSelectedHorizontal();
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.V)
            {
                ReflectSelectedVertical();
                e.Handled = true;
            }
            else if (e.KeyCode == Keys.Back)
            {
                DeleteSelectedShape();
                e.Handled = true;
            }
        }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);

            foreach (Shape shape in shapes)
                shape.Draw(e.Graphics);

            if (isPreviewing && clickNumber == 1)
            {
                Shape previewShape = BuildShape(currentMode, previewStart, previewCurrent);
                if (previewShape != null)
                    previewShape.DrawPreview(e.Graphics);
            }
        }
    }

    abstract class Shape
    {
        public bool IsSelected { get; set; }
        protected const int HandleSize = 8;

        public abstract void Draw(Graphics g);
        public abstract Shape Clone();

        public virtual void DrawPreview(Graphics g)
        {
            using (Pen pen = new Pen(Color.Gray, 1))
            {
                pen.DashStyle = DashStyle.Dash;
                DrawWithPen(g, pen);
            }
        }

        protected abstract void DrawWithPen(Graphics g, Pen pen);

        public abstract void Move(float dx, float dy);
        public abstract void Rotate(float angleDeg);
        public abstract void Scale(float factor);
        public abstract void ReflectHorizontal();
        public abstract void ReflectVertical();
        public abstract bool HitTest(Point p);
        public abstract PointF GetCentre();

        public abstract int HitHandle(Point p);
        public abstract void ResizeByHandle(int handleIndex, Point p);

        protected void DrawHandle(Graphics g, Brush brush, PointF pt)
        {
            g.FillRectangle(brush, pt.X - HandleSize / 2, pt.Y - HandleSize / 2, HandleSize, HandleSize);
        }

        protected bool PointHitsHandle(Point p, PointF handlePoint)
        {
            RectangleF rect = new RectangleF(
                handlePoint.X - HandleSize / 2,
                handlePoint.Y - HandleSize / 2,
                HandleSize,
                HandleSize);

            return rect.Contains(p);
        }

        protected PointF RotatePoint(PointF point, PointF pivot, float angleDeg)
        {
            float rad = angleDeg * (float)Math.PI / 180f;
            float cos = (float)Math.Cos(rad);
            float sin = (float)Math.Sin(rad);

            float tx = point.X - pivot.X;
            float ty = point.Y - pivot.Y;

            float rx = (tx * cos) - (ty * sin);
            float ry = (tx * sin) + (ty * cos);

            return new PointF(rx + pivot.X, ry + pivot.Y);
        }

        protected void DrawPolyline(Graphics g, Pen pen, PointF[] pts, bool closed)
        {
            for (int i = 0; i < pts.Length - 1; i++)
                g.DrawLine(pen, pts[i], pts[i + 1]);

            if (closed && pts.Length > 2)
                g.DrawLine(pen, pts[pts.Length - 1], pts[0]);
        }
    }

    abstract class PolygonShape : Shape
    {
        protected PointF[] points;

        public override void Draw(Graphics g)
        {
            using (Pen pen = new Pen(IsSelected ? Color.Red : Color.Black, IsSelected ? 3 : 2))
            {
                DrawWithPen(g, pen);
            }

            if (IsSelected)
            {
                foreach (PointF pt in points)
                    DrawHandle(g, Brushes.Blue, pt);
            }
        }

        protected override void DrawWithPen(Graphics g, Pen pen)
        {
            DrawPolyline(g, pen, points, true);
        }

        public override void Move(float dx, float dy)
        {
            for (int i = 0; i < points.Length; i++)
                points[i] = new PointF(points[i].X + dx, points[i].Y + dy);
        }

        public override void Rotate(float angleDeg)
        {
            PointF centre = GetCentre();

            for (int i = 0; i < points.Length; i++)
                points[i] = RotatePoint(points[i], centre, angleDeg);
        }

        public override void Scale(float factor)
        {
            if (factor <= 0f)
                return;

            PointF centre = GetCentre();

            for (int i = 0; i < points.Length; i++)
            {
                float dx = points[i].X - centre.X;
                float dy = points[i].Y - centre.Y;

                points[i] = new PointF(
                    centre.X + dx * factor,
                    centre.Y + dy * factor);
            }
        }

        public override void ReflectHorizontal()
        {
            PointF centre = GetCentre();

            for (int i = 0; i < points.Length; i++)
                points[i] = new PointF(points[i].X, 2 * centre.Y - points[i].Y);
        }

        public override void ReflectVertical()
        {
            PointF centre = GetCentre();

            for (int i = 0; i < points.Length; i++)
                points[i] = new PointF(2 * centre.X - points[i].X, points[i].Y);
        }

        public override bool HitTest(Point p)
        {
            return PointInPolygon(p, points);
        }

        public override PointF GetCentre()
        {
            float sumX = 0;
            float sumY = 0;

            for (int i = 0; i < points.Length; i++)
            {
                sumX += points[i].X;
                sumY += points[i].Y;
            }

            return new PointF(sumX / points.Length, sumY / points.Length);
        }

        public override int HitHandle(Point p)
        {
            if (!IsSelected)
                return -1;

            for (int i = 0; i < points.Length; i++)
            {
                if (PointHitsHandle(p, points[i]))
                    return i;
            }

            return -1;
        }

        public override void ResizeByHandle(int handleIndex, Point p)
        {
            if (handleIndex < 0 || handleIndex >= points.Length)
                return;

            points[handleIndex] = new PointF(p.X, p.Y);
        }

        protected PointF[] ClonePoints()
        {
            PointF[] cloned = new PointF[points.Length];
            Array.Copy(points, cloned, points.Length);
            return cloned;
        }

        private bool PointInPolygon(Point p, PointF[] poly)
        {
            bool inside = false;

            for (int i = 0, j = poly.Length - 1; i < poly.Length; j = i++)
            {
                bool intersect =
                    ((poly[i].Y > p.Y) != (poly[j].Y > p.Y)) &&
                    (p.X < (poly[j].X - poly[i].X) * (p.Y - poly[i].Y) / ((poly[j].Y - poly[i].Y) + 0.0001f) + poly[i].X);

                if (intersect)
                    inside = !inside;
            }

            return inside;
        }

        protected static RectangleF GetBounds(Point p1, Point p2)
        {
            float left = Math.Min(p1.X, p2.X);
            float right = Math.Max(p1.X, p2.X);
            float top = Math.Min(p1.Y, p2.Y);
            float bottom = Math.Max(p1.Y, p2.Y);

            return new RectangleF(left, top, right - left, bottom - top);
        }

        protected static PointF[] BuildRegularPolygonPoints(RectangleF bounds, int sides, float startAngleDeg)
        {
            PointF[] pts = new PointF[sides];
            float cx = bounds.Left + bounds.Width / 2f;
            float cy = bounds.Top + bounds.Height / 2f;
            float rx = bounds.Width / 2f;
            float ry = bounds.Height / 2f;

            for (int i = 0; i < sides; i++)
            {
                float angleDeg = startAngleDeg + (360f / sides) * i;
                float angleRad = angleDeg * (float)Math.PI / 180f;

                pts[i] = new PointF(
                    cx + rx * (float)Math.Cos(angleRad),
                    cy + ry * (float)Math.Sin(angleRad));
            }

            return pts;
        }
    }

    class Square : PolygonShape
    {
        public Square(Point keyPt, Point oppPt)
        {
            points = BuildPointsFromOppositeCorners(
                new PointF(keyPt.X, keyPt.Y),
                new PointF(oppPt.X, oppPt.Y));
        }

        public override Shape Clone()
        {
            Square copy = new Square(Point.Empty, new Point(1, 1));
            copy.points = ClonePoints();
            copy.IsSelected = IsSelected;
            return copy;
        }

        public override void ResizeByHandle(int handleIndex, Point p)
        {
            if (handleIndex < 0 || handleIndex > 3)
                return;

            int oppositeIndex = (handleIndex + 2) % 4;
            PointF oppositePoint = points[oppositeIndex];
            PointF draggedPoint = new PointF(p.X, p.Y);

            PointF[] rebuilt = BuildPointsFromOppositeCorners(draggedPoint, oppositePoint);

            PointF[] reordered = new PointF[4];
            for (int i = 0; i < 4; i++)
                reordered[i] = rebuilt[(i - handleIndex + 4) % 4];

            points = reordered;
        }

        private PointF[] BuildPointsFromOppositeCorners(PointF keyPt, PointF oppPt)
        {
            double xDiff = oppPt.X - keyPt.X;
            double yDiff = oppPt.Y - keyPt.Y;
            double xMid = (oppPt.X + keyPt.X) / 2.0;
            double yMid = (oppPt.Y + keyPt.Y) / 2.0;

            PointF p1 = new PointF(keyPt.X, keyPt.Y);
            PointF p2 = new PointF((float)(xMid + yDiff / 2.0), (float)(yMid - xDiff / 2.0));
            PointF p3 = new PointF(oppPt.X, oppPt.Y);
            PointF p4 = new PointF((float)(xMid - yDiff / 2.0), (float)(yMid + xDiff / 2.0));

            return new PointF[] { p1, p2, p3, p4 };
        }
    }

    class Triangle : PolygonShape
    {
        public Triangle(Point p1, Point p2)
        {
            float left = Math.Min(p1.X, p2.X);
            float right = Math.Max(p1.X, p2.X);
            float top = Math.Min(p1.Y, p2.Y);
            float bottom = Math.Max(p1.Y, p2.Y);

            PointF a = new PointF((left + right) / 2f, top);
            PointF b = new PointF(right, bottom);
            PointF c = new PointF(left, bottom);

            points = new PointF[] { a, b, c };
        }

        public override Shape Clone()
        {
            Triangle copy = new Triangle(Point.Empty, new Point(1, 1));
            copy.points = ClonePoints();
            copy.IsSelected = IsSelected;
            return copy;
        }
    }

