    class DiamondShape : PolygonShape
    {
        public DiamondShape(Point p1, Point p2)
        {
            RectangleF b = GetBounds(p1, p2);
            float cx = b.Left + b.Width / 2f;
            float cy = b.Top + b.Height / 2f;

            points = new PointF[]
            {
                new PointF(cx, b.Top),
                new PointF(b.Right, cy),
                new PointF(cx, b.Bottom),
                new PointF(b.Left, cy)
            };
        }

        public override Shape Clone()
        {
            DiamondShape copy = new DiamondShape(Point.Empty, new Point(1, 1));
            copy.points = ClonePoints();
            copy.IsSelected = IsSelected;
            return copy;
        }
    }

    class StarShape : PolygonShape
    {
        public StarShape(Point p1, Point p2)
        {
            RectangleF b = GetBounds(p1, p2);

            float cx = b.Left + b.Width / 2f;
            float cy = b.Top + b.Height / 2f;
            float outerRx = b.Width / 2f;
            float outerRy = b.Height / 2f;
            float innerRx = outerRx * 0.45f;
            float innerRy = outerRy * 0.45f;

            points = new PointF[10];

            for (int i = 0; i < 10; i++)
            {
                float angleDeg = -90f + i * 36f;
                float angleRad = angleDeg * (float)Math.PI / 180f;

                float rx = (i % 2 == 0) ? outerRx : innerRx;
                float ry = (i % 2 == 0) ? outerRy : innerRy;

                points[i] = new PointF(
                    cx + rx * (float)Math.Cos(angleRad),
                    cy + ry * (float)Math.Sin(angleRad));
            }
        }

        public override Shape Clone()
        {
            StarShape copy = new StarShape(Point.Empty, new Point(1, 1));
            copy.points = ClonePoints();
            copy.IsSelected = IsSelected;
            return copy;
        }
    }

    class CircleShape : Shape
    {
        private PointF centre;
        private float radius;

        public CircleShape(Point p1, Point p2)
        {
            centre = new PointF((p1.X + p2.X) / 2f, (p1.Y + p2.Y) / 2f);

            float dx = p2.X - p1.X;
            float dy = p2.Y - p1.Y;

            radius = (float)Math.Sqrt(dx * dx + dy * dy) / 2f;

            if (radius < 1)
                radius = 1;
        }

        public override Shape Clone()
        {
            CircleShape copy = new CircleShape(Point.Empty, new Point(2, 0));
            copy.centre = centre;
            copy.radius = radius;
            copy.IsSelected = IsSelected;
            return copy;
        }

        public override void Draw(Graphics g)
        {
            using (Pen pen = new Pen(IsSelected ? Color.Red : Color.Black, IsSelected ? 3 : 2))
            {
                DrawWithPen(g, pen);
            }

            if (IsSelected)
            {
                DrawHandle(g, Brushes.Blue, GetResizeHandlePoint());
            }
        }

        protected override void DrawWithPen(Graphics g, Pen pen)
        {
            PointF[] pts = BuildCirclePoints(72);

            for (int i = 0; i < pts.Length - 1; i++)
                g.DrawLine(pen, pts[i], pts[i + 1]);

            g.DrawLine(pen, pts[pts.Length - 1], pts[0]);
        }

        public override void Move(float dx, float dy)
        {
            centre = new PointF(centre.X + dx, centre.Y + dy);
        }

        public override void Rotate(float angleDeg)
        {
        }

        public override void Scale(float factor)
        {
            if (factor <= 0f)
                return;

            radius *= factor;
            if (radius < 1) radius = 1;
        }

        public override void ReflectHorizontal()
        {
        }

        public override void ReflectVertical()
        {
        }

        public override bool HitTest(Point p)
        {
            float dx = p.X - centre.X;
            float dy = p.Y - centre.Y;
            float distance = (float)Math.Sqrt(dx * dx + dy * dy);

            return distance <= radius;
        }

        public override PointF GetCentre()
        {
            return centre;
        }

        public override int HitHandle(Point p)
        {
            if (!IsSelected)
                return -1;

            return PointHitsHandle(p, GetResizeHandlePoint()) ? 0 : -1;
        }

        public override void ResizeByHandle(int handleIndex, Point p)
        {
            if (handleIndex != 0)
                return;

            float dx = p.X - centre.X;
            float dy = p.Y - centre.Y;
            radius = (float)Math.Sqrt(dx * dx + dy * dy);

            if (radius < 1)
                radius = 1;
        }

        private PointF GetResizeHandlePoint()
        {
            return new PointF(centre.X + radius, centre.Y);
        }

        private PointF[] BuildCirclePoints(int segments)
        {
            PointF[] pts = new PointF[segments];

            for (int i = 0; i < segments; i++)
            {
                float angle = (float)(2 * Math.PI * i / segments);
                float x = centre.X + radius * (float)Math.Cos(angle);
                float y = centre.Y + radius * (float)Math.Sin(angle);
                pts[i] = new PointF(x, y);
            }

            return pts;
        }
    }

    class EllipseShape : Shape
    {
        private PointF centre;
        private float radiusX;
        private float radiusY;
        private float rotationAngleDeg;

        public EllipseShape(Point p1, Point p2)
        {
            centre = new PointF((p1.X + p2.X) / 2f, (p1.Y + p2.Y) / 2f);
            radiusX = Math.Abs(p2.X - p1.X) / 2f;
            radiusY = Math.Abs(p2.Y - p1.Y) / 2f;
            rotationAngleDeg = 0f;

            if (radiusX < 1) radiusX = 1;
            if (radiusY < 1) radiusY = 1;
        }

        public override Shape Clone()
        {
            EllipseShape copy = new EllipseShape(Point.Empty, new Point(2, 1));
            copy.centre = centre;
            copy.radiusX = radiusX;
            copy.radiusY = radiusY;
            copy.rotationAngleDeg = rotationAngleDeg;
            copy.IsSelected = IsSelected;
            return copy;
        }

        public override void Draw(Graphics g)
        {
            using (Pen pen = new Pen(IsSelected ? Color.Red : Color.Black, IsSelected ? 3 : 2))
            {
                DrawWithPen(g, pen);
            }

            if (IsSelected)
            {
                DrawHandle(g, Brushes.Blue, GetXHandlePoint());
                DrawHandle(g, Brushes.Blue, GetYHandlePoint());
            }
        }

        protected override void DrawWithPen(Graphics g, Pen pen)
        {
            PointF[] pts = BuildEllipsePoints(96);

            for (int i = 0; i < pts.Length - 1; i++)
                g.DrawLine(pen, pts[i], pts[i + 1]);

            g.DrawLine(pen, pts[pts.Length - 1], pts[0]);
        }

        public override void Move(float dx, float dy)
        {
            centre = new PointF(centre.X + dx, centre.Y + dy);
        }

        public override void Rotate(float angleDeg)
        {
            rotationAngleDeg += angleDeg;
        }

        public override void Scale(float factor)
        {
            if (factor <= 0f)
                return;

            radiusX *= factor;
            radiusY *= factor;

            if (radiusX < 1) radiusX = 1;
            if (radiusY < 1) radiusY = 1;
        }

        public override void ReflectHorizontal()
        {
            rotationAngleDeg = -rotationAngleDeg;
        }

        public override void ReflectVertical()
        {
            rotationAngleDeg = -rotationAngleDeg;
        }

        public override bool HitTest(Point p)
        {
            PointF local = ToLocalCoordinates(p);
            float value = (local.X * local.X) / (radiusX * radiusX) +
                          (local.Y * local.Y) / (radiusY * radiusY);

            return value <= 1f;
        }

        public override PointF GetCentre()
        {
            return centre;
        }

        public override int HitHandle(Point p)
        {
            if (!IsSelected)
                return -1;

            if (PointHitsHandle(p, GetXHandlePoint()))
                return 0;

            if (PointHitsHandle(p, GetYHandlePoint()))
                return 1;

            return -1;
        }

        public override void ResizeByHandle(int handleIndex, Point p)
        {
            PointF local = ToLocalCoordinates(p);

            if (handleIndex == 0)
            {
                radiusX = Math.Abs(local.X);
                if (radiusX < 1) radiusX = 1;
            }
            else if (handleIndex == 1)
            {
                radiusY = Math.Abs(local.Y);
                if (radiusY < 1) radiusY = 1;
            }
        }

        private PointF[] BuildEllipsePoints(int segments)
        {
            PointF[] pts = new PointF[segments];

            for (int i = 0; i < segments; i++)
            {
                float angle = (float)(2 * Math.PI * i / segments);
                PointF local = new PointF(
                    radiusX * (float)Math.Cos(angle),
                    radiusY * (float)Math.Sin(angle));

                pts[i] = RotatePoint(
                    new PointF(centre.X + local.X, centre.Y + local.Y),
                    centre,
                    rotationAngleDeg);
            }

            return pts;
        }

        private PointF GetXHandlePoint()
        {
            return RotatePoint(new PointF(centre.X + radiusX, centre.Y), centre, rotationAngleDeg);
        }

        private PointF GetYHandlePoint()
        {
            return RotatePoint(new PointF(centre.X, centre.Y + radiusY), centre, rotationAngleDeg);
        }

        private PointF ToLocalCoordinates(Point p)
        {
            float rad = -rotationAngleDeg * (float)Math.PI / 180f;
            float cos = (float)Math.Cos(rad);
            float sin = (float)Math.Sin(rad);

            float tx = p.X - centre.X;
            float ty = p.Y - centre.Y;

            float lx = tx * cos - ty * sin;
            float ly = tx * sin + ty * cos;

            return new PointF(lx, ly);
        }
    }

    class Prompt
    {
        public static string ShowDialog(string text, string caption)
        {
            Form prompt = new Form()
            {
                Width = 360,
                Height = 185,
                FormBorderStyle = FormBorderStyle.FixedDialog,
                Text = caption,
                StartPosition = FormStartPosition.CenterParent,
                MinimizeBox = false,
                MaximizeBox = false
            };

            Label textLabel = new Label()
            {
                Left = 15,
                Top = 15,
                Width = 310,
                Height = 50,
                Text = text
            };

            TextBox inputBox = new TextBox()
            {
                Left = 15,
                Top = 72,
                Width = 310
            };

            Button confirmation = new Button()
            {
                Text = "OK",
                Left = 170,
                Width = 75,
                Top = 108,
                DialogResult = DialogResult.OK
            };

            Button cancel = new Button()
            {
                Text = "Cancel",
                Left = 250,
                Width = 75,
                Top = 108,
                DialogResult = DialogResult.Cancel
            };

            prompt.Controls.Add(textLabel);
            prompt.Controls.Add(inputBox);
            prompt.Controls.Add(confirmation);
            prompt.Controls.Add(cancel);

            prompt.AcceptButton = confirmation;
            prompt.CancelButton = cancel;

            return prompt.ShowDialog() == DialogResult.OK ? inputBox.Text : "";
        }
    }

    class EditorState
    {
        public List<Shape> Shapes { get; private set; }
        public int SelectedIndex { get; private set; }

        public EditorState(List<Shape> sourceShapes, Shape selectedShape)
        {
            Shapes = new List<Shape>();

            for (int i = 0; i < sourceShapes.Count; i++)
                Shapes.Add(sourceShapes[i].Clone());

            SelectedIndex = -1;
            if (selectedShape != null)
                SelectedIndex = sourceShapes.IndexOf(selectedShape);
        }
    }
