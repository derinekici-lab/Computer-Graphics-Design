        private void RotateSelectedByCustomAngle(object sender, EventArgs e)
        {
            if (selectedShape == null)
            {
                MessageBox.Show("Please select a shape first.");
                UpdateStatus("Custom rotation failed. No shape selected.");
                return;
            }

            string input = Prompt.ShowDialog(
                "Enter rotation angle in degrees.\nExamples: 90, -45, 180",
                "Rotate by Angle");

            if (string.IsNullOrWhiteSpace(input))
            {
                UpdateStatus("Custom rotation cancelled.");
                return;
            }

            float angle;
            if (!TryParseFloat(input, out angle))
            {
                MessageBox.Show("Please enter a valid numeric angle.");
                UpdateStatus("Custom rotation failed. Invalid angle.");
                return;
            }

            SaveStateForUndo();
            selectedShape.Rotate(angle);
            Invalidate();
            UpdateStatus(GetShapeDisplayName(selectedShape) + " rotated by " + angle + " degrees.");
        }

        private void ScaleSelected(float factor)
        {
            if (selectedShape == null)
            {
                MessageBox.Show("Please select a shape first.");
                UpdateStatus("Scaling failed. No shape selected.");
                return;
            }

            if (factor <= 0f)
            {
                MessageBox.Show("Scale factor must be greater than zero.");
                UpdateStatus("Scaling failed. Invalid factor.");
                return;
            }

            SaveStateForUndo();
            selectedShape.Scale(factor);
            Invalidate();
            UpdateStatus(GetShapeDisplayName(selectedShape) + " scaled by factor " + factor.ToString("0.##") + ".");
        }

        private void ScaleSelectedByFactor(object sender, EventArgs e)
        {
            if (selectedShape == null)
            {
                MessageBox.Show("Please select a shape first.");
                UpdateStatus("Custom scaling failed. No shape selected.");
                return;
            }

            string input = Prompt.ShowDialog(
                "Enter scale factor.\nExamples: 1.1 = enlarge 10%\n0.9 = reduce 10%\n2 = double size",
                "Scale by Factor");

            if (string.IsNullOrWhiteSpace(input))
            {
                UpdateStatus("Custom scaling cancelled.");
                return;
            }

            float factor;
            if (!TryParseFloat(input, out factor) || factor <= 0f)
            {
                MessageBox.Show("Please enter a valid factor greater than zero.");
                UpdateStatus("Custom scaling failed. Invalid factor.");
                return;
            }

            SaveStateForUndo();
            selectedShape.Scale(factor);
            Invalidate();
            UpdateStatus(GetShapeDisplayName(selectedShape) + " scaled by factor " + factor.ToString("0.##") + ".");
        }

        private bool TryParseFloat(string input, out float value)
        {
            string cleaned = input.Trim();

            if (float.TryParse(cleaned, NumberStyles.Float, CultureInfo.CurrentCulture, out value))
                return true;

            if (float.TryParse(cleaned, NumberStyles.Float, CultureInfo.InvariantCulture, out value))
                return true;

            cleaned = cleaned.Replace(',', '.');
            return float.TryParse(cleaned, NumberStyles.Float, CultureInfo.InvariantCulture, out value);
        }

