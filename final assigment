        private void deleteShape(object sender, EventArgs e)
        {
            DeleteSelectedShape();
        }

        private void DeleteSelectedShape()
        {
            if (selectedShape == null)
            {
                MessageBox.Show("No shape is selected.");
                UpdateStatus("Delete failed. No shape selected.");
                return;
            }

            SaveStateForUndo();
            string deletedName = GetShapeDisplayName(selectedShape);
            shapes.Remove(selectedShape);
            selectedShape = null;
            Invalidate();
            UpdateStatus(deletedName + " deleted.");
        }

        private void clearAllShapes(object sender, EventArgs e)
        {
            if (shapes.Count == 0)
            {
                UpdateStatus("Canvas is already empty.");
                return;
            }

            SaveStateForUndo();
            shapes.Clear();
            selectedShape = null;
            ResetInteractionFlags();
            currentMode = EditorMode.None;
            Invalidate();
            UpdateStatus("All shapes cleared.");
        }

        private void mouseClick(object sender, MouseEventArgs e)
        {
            if (e.Button != MouseButtons.Left)
                return;

            if (IsCreateMode(currentMode))
            {
                if (clickNumber == 0)
                {
                    firstClick = e.Location;
                    previewStart = e.Location;
                    previewCurrent = e.Location;
                    clickNumber = 1;
                    isPreviewing = true;
                    Invalidate();
                    UpdateStatus("First point chosen. Move the mouse and click again.");
                }
                else
                {
                    secondClick = e.Location;
                    clickNumber = 0;
                    isPreviewing = false;

                    Shape newShape = BuildShape(currentMode, firstClick, secondClick);

                    if (newShape != null)
                    {
                        SaveStateForUndo();
                        shapes.Add(newShape);
                        SelectOnly(newShape);
                        selectedShape = newShape;
                        Invalidate();
                        UpdateStatus(GetShapeDisplayName(newShape) + " created.");
                    }

                    currentMode = EditorMode.None;
                }
            }
        }

        private bool IsCreateMode(EditorMode mode)
        {
            return mode == EditorMode.CreateSquare ||
                   mode == EditorMode.CreateTriangle ||
                   mode == EditorMode.CreateCircle ||
                   mode == EditorMode.CreatePentagon ||
                   mode == EditorMode.CreateHexagon ||
                   mode == EditorMode.CreateStar ||
                   mode == EditorMode.CreateDiamond ||
                   mode == EditorMode.CreateEllipse;
        }

        private void Form1_MouseDown(object sender, MouseEventArgs e)
        {
            if (e.Button != MouseButtons.Left)
                return;

            if (IsCreateMode(currentMode))
                return;

            didDragOrResize = false;
            interactionUndoSaved = false;

            if (selectedShape != null)
            {
                int handleIndex = selectedShape.HitHandle(e.Location);
                if (handleIndex >= 0)
                {
                    isResizingShape = true;
                    activeHandleIndex = handleIndex;
                    UpdateStatus(GetShapeDisplayName(selectedShape) + " resize started.");
                    return;
                }
            }

            Shape hitShape = FindShapeAtPoint(e.Location);
            selectedShape = hitShape;
            SelectOnly(selectedShape);
            Invalidate();

            if (selectedShape != null)
            {
                isDraggingShape = true;
                lastMousePoint = e.Location;
                UpdateStatus(GetShapeDisplayName(selectedShape) + " selected automatically.");
            }
            else
            {
                UpdateStatus("Selection cleared.");
            }
        }

        private void Form1_MouseUp(object sender, MouseEventArgs e)
        {
            if (isDraggingShape && selectedShape != null && didDragOrResize)
                UpdateStatus(GetShapeDisplayName(selectedShape) + " moved by drag-and-drop.");

            if (isResizingShape && selectedShape != null && didDragOrResize)
                UpdateStatus(GetShapeDisplayName(selectedShape) + " resized.");

            isDraggingShape = false;
            isResizingShape = false;
            activeHandleIndex = -1;
            interactionUndoSaved = false;
        }

        private void Form1_MouseMove(object sender, MouseEventArgs e)
        {
            if (isResizingShape && selectedShape != null && activeHandleIndex >= 0)
            {
                if (!interactionUndoSaved)
                {
                    SaveStateForUndo();
                    interactionUndoSaved = true;
                }

                selectedShape.ResizeByHandle(activeHandleIndex, e.Location);
                didDragOrResize = true;
                Invalidate();
                return;
            }

            if (isDraggingShape && selectedShape != null)
            {
                float dx = e.X - lastMousePoint.X;
                float dy = e.Y - lastMousePoint.Y;

                if (dx != 0 || dy != 0)
                {
                    if (!interactionUndoSaved)
                    {
                        SaveStateForUndo();
                        interactionUndoSaved = true;
                    }

                    selectedShape.Move(dx, dy);
                    lastMousePoint = e.Location;
                    didDragOrResize = true;
                    Invalidate();
                }
                return;
            }

            if (isPreviewing && clickNumber == 1)
            {
                previewCurrent = e.Location;
                Invalidate();
            }
        }

        private Shape BuildShape(EditorMode mode, Point p1, Point p2)
        {
            if (mode == EditorMode.CreateSquare)
                return new Square(p1, p2);
            if (mode == EditorMode.CreateTriangle)
                return new Triangle(p1, p2);
            if (mode == EditorMode.CreateCircle)
                return new CircleShape(p1, p2);
            if (mode == EditorMode.CreatePentagon)
                return new PentagonShape(p1, p2);
            if (mode == EditorMode.CreateHexagon)
                return new HexagonShape(p1, p2);
            if (mode == EditorMode.CreateStar)
                return new StarShape(p1, p2);
            if (mode == EditorMode.CreateDiamond)
                return new DiamondShape(p1, p2);
            if (mode == EditorMode.CreateEllipse)
                return new EllipseShape(p1, p2);

            return null;
        }

        private Shape FindShapeAtPoint(Point p)
        {
            for (int i = shapes.Count - 1; i >= 0; i--)
            {
                if (shapes[i].HitTest(p))
                    return shapes[i];
            }

            return null;
        }

        private void SelectOnly(Shape shapeToSelect)
        {
            foreach (Shape s in shapes)
                s.IsSelected = false;

            if (shapeToSelect != null)
                shapeToSelect.IsSelected = true;
        }

